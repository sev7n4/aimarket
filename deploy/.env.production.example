# 复制到 /opt/aimarket/.env（勿提交 Git）
# cp deploy/.env.production.example .env

# --- 公网访问（按实际 IP 修改）---
NEXT_PUBLIC_API_URL=http://119.29.173.89:4100
CORS_ORIGIN=http://119.29.173.89:3100
PUBLIC_WEB_URL=http://119.29.173.89:3100

# --- API 核心（必填，请替换占位符）---
PORT=4000
JWT_SECRET=请替换为随机长字符串
ADMIN_SECRET=请替换为随机管理密钥
DATABASE_PATH=/app/data/aimarket.db
UPLOAD_DIR=/app/uploads
MOCK_GENERATION_DELAY_MS=2500

# --- 图像 / Studio 工具（P4，详见 docs/PRODUCTION_SECRETS.md）---
# 首期可全部 mock；接真供应商时改 auto/openai 并配置 OPENAI_API_KEY
IMAGE_PROVIDER=mock
TOOL_IMAGE_PROVIDER=auto
PROMPT_OPTIMIZE_PROVIDER=auto

# Studio 抠图真供应商（auto：有 URL 走 HTTP，失败回落 mock）
# TOOL_CUTOUT_PROVIDER=auto
# TOOL_CUTOUT_HTTP_URL=
# TOOL_CUTOUT_HTTP_KEY=

# Studio 超分 / 增强真供应商（upscale + enhance 共享）
# TOOL_UPSCALE_PROVIDER=auto
# TOOL_UPSCALE_HTTP_URL=
# TOOL_UPSCALE_HTTP_KEY=

# OpenAI（仅填在服务器 .env，禁止进 Git）
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- 审核 / 队列 / 存储 ---
MODERATION_PROVIDER=local
MODERATION_OUTPUT=true
JOB_QUEUE=memory
STORAGE_PROVIDER=local

# --- 可选 Redis（与 pintuotuo 6379 隔离）---
# JOB_QUEUE=redis
# REDIS_URL=redis://aimarket-redis:6379
# RATE_LIMIT_STORE=redis

# --- 可选 S3 / COS ---
# STORAGE_PROVIDER=s3
# S3_BUCKET=
# S3_REGION=ap-guangzhou
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=

# --- 可选支付 / 视频 ---
# PAYMENT_PROVIDER=mock
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# VIDEO_PROVIDER=mock
