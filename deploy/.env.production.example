# 复制到 /opt/aimarket/.env（勿提交 Git）
# cp deploy/.env.production.example .env

# --- 公网访问（按实际 IP 修改）---
NEXT_PUBLIC_API_URL=http://119.29.173.89:4100
# API 容器内：供 Seedream 等外部服务拉取 /uploads/ 引用图（与 NEXT_PUBLIC_API_URL 同源）
API_PUBLIC_URL=http://119.29.173.89:4100
CORS_ORIGIN=http://119.29.173.89:3100
PUBLIC_WEB_URL=http://119.29.173.89:3100

# --- API 核心（必填，请替换占位符）---
PORT=4000
JWT_SECRET=请替换为随机长字符串
ADMIN_SECRET=请替换为随机管理密钥
DATABASE_PATH=/app/data/aimarket.db
UPLOAD_DIR=/app/uploads
MOCK_GENERATION_DELAY_MS=2500

# --- 图像 / Studio 工具（P4，详见 docs/PRODUCTION_SECRETS.md）---
# 首期可全部 mock；接真供应商时改 auto/openai 并配置 OPENAI_API_KEY
## 图像生成 Provider（auto/agnes/aliyun_wan 均 Agnes → 万相 → Seedream 回落）
IMAGE_PROVIDER=auto
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
ALIYUN_WAN_MODEL=wan2.6-t2i
# 图生图专用万相模型（与 t2i 分离；IMAGE_PROVIDER=aliyun_wan 时优先用于参考图生成）
ALIYUN_WAN_I2I_MODEL=wan2.6-image

## Studio 工具：默认 auto + 火山方舟 Seedream 5（cutout/upscale/inpaint 等）
TOOL_IMAGE_PROVIDER=auto
TOOL_CUTOUT_PROVIDER=auto
TOOL_UPSCALE_PROVIDER=auto
TOOL_EDIT_PROVIDER=auto
# 扩图：auto 时优先万相真扩图（需 DASHSCOPE_API_KEY，与 IMAGE_PROVIDER 共用）
TOOL_EXPAND_PROVIDER=auto
ALIYUN_WAN_EXPAND_MODEL=wanx2.1-imageedit
# TOOL_EXPAND_HTTP_URL=
# TOOL_EXPAND_HTTP_KEY=
# 变体：auto 时 OpenAI（dall-e-2 /images/variations）优先，否则 Seedream 模拟变体
TOOL_VARIATION_PROVIDER=auto
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_MODEL=doubao-seedream-5-0-260128

## Agnes（图生图 / 视频兜底；Key 仅填服务器 .env，禁止进 Git）
# AGNES_API_KEY=
# AGNES_API_BASE_URL=https://apihub.agnes-ai.com/v1
# AGNES_IMAGE_MODEL=agnes-image-2.1-flash
# AGNES_VIDEO_MODEL=agnes-video-v2.0
# AGNES_VIDEO_POLL_INTERVAL_MS=8000
# 视频轮询上限（毫秒）；Agnes 繁忙时单任务可达 5–15 分钟，建议 900000（15 分钟）
# AGNES_VIDEO_POLL_TIMEOUT_MS=900000
# JOB_WATCHDOG_VIDEO_BUFFER_MS=120000
# JOB_MAX_RUNNING_MS=900000
# JOB_WATCHDOG_SWEEP_INTERVAL_MS=60000

PROMPT_OPTIMIZE_PROVIDER=auto
# 生产有 DASHSCOPE_API_KEY 时 auto 优先走百炼 Chat 润色
# PROMPT_OPTIMIZE_DASHSCOPE_MODEL=qwen-plus

# Auto 文生图：单供应商尝试超时（毫秒）与 job SSE 最长监听
# AUTO_PROVIDER_ATTEMPT_TIMEOUT_MS=75000
# JOB_STREAM_MAX_MS=900000

## HTTP 真供应商（如果走自建网关接 Replicate/Fal/等，可同时与 Seedream 并存；auto 优先 Seedream）
# TOOL_CUTOUT_HTTP_URL=
# TOOL_CUTOUT_HTTP_KEY=
# TOOL_UPSCALE_HTTP_URL=
# TOOL_UPSCALE_HTTP_KEY=
# TOOL_EDIT_HTTP_URL=
# TOOL_EDIT_HTTP_KEY=

# OpenAI（仅填在服务器 .env，禁止进 Git）
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- 审核 / 队列 / 存储 ---
MODERATION_PROVIDER=local
MODERATION_OUTPUT=true
JOB_QUEUE=memory
STORAGE_PROVIDER=local

# --- 可选 Redis（与 pintuotuo 6379 隔离）---
# JOB_QUEUE=redis
# REDIS_URL=redis://aimarket-redis:6379
# RATE_LIMIT_STORE=redis
# 多 API 实例共享 LangGraph 状态（需 Redis Stack / RediSearch）
# AGENT_CHECKPOINTER=redis
# AGENT_CHECKPOINT_REDIS_TTL_MINUTES=10080
# AGENT_VLM_ENABLED=true

# --- 可选 S3 / COS ---
# STORAGE_PROVIDER=s3
# S3_BUCKET=
# S3_REGION=ap-guangzhou
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=

# --- 可选支付 / 视频 ---
# PAYMENT_PROVIDER=mock
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# VIDEO_PROVIDER=mock
# 配置 AGNES_API_KEY 后 auto 模式视频优先走 Agnes（seedance-2 为 Agnes 别名）
# VIDEO_PROVIDER=agnes
# HTTP 视频网关（seedance-2 / wan-2.6）；配置后优先于万相/Agnes
# VIDEO_API_URL=https://your-video-gateway.example.com
# VIDEO_API_KEY=
# 万相 2.7 视频（DASHSCOPE_API_KEY 与图像共用）
# ALIYUN_WAN_VIDEO_T2V_MODEL=wan2.7-t2v
# ALIYUN_WAN_VIDEO_I2V_MODEL=wan2.7-i2v
# ALIYUN_WAN_VIDEO_R2V_MODEL=wan2.7-r2v
# ALIYUN_WAN_VIDEO_POLL_INTERVAL_MS=5000
# ALIYUN_WAN_VIDEO_POLL_TIMEOUT_MS=900000
