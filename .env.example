# Web (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4000
# 默认 true：生成任务走 SSE（失败降级轮询）；设 false 仅轮询
NEXT_PUBLIC_USE_JOB_STREAM=true

# API (apps/api)
PORT=4000
# 外部供应商（Seedream 等）拉取 /uploads/ 时的公网根地址；本地可与 NEXT_PUBLIC_API_URL 相同
API_PUBLIC_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-in-production
DATABASE_PATH=./data/aimarket.db
# PostgreSQL（可选，见 docs/DEPLOY.md；需运行 postgres-bootstrap 迁移）
# DATABASE_URL=postgresql://user:pass@localhost:5432/aimarket

UPLOAD_DIR=./uploads

# 对象存储 / CDN（local | s3 | auto）
STORAGE_PROVIDER=auto
S3_BUCKET=
S3_REGION=ap-guangzhou
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=
S3_PREFIX=uploads/
S3_FORCE_PATH_STYLE=false
S3_ACL=public-read
MOCK_GENERATION_DELAY_MS=2500
PUBLIC_WEB_URL=http://localhost:3000

# 图像生成 Provider（mock | openai | aliyun_wan | auto）
# auto 优先级：aliyun_wan（DASHSCOPE_API_KEY）→ openai（OPENAI_API_KEY）→ mock
IMAGE_PROVIDER=auto

# 阿里百炼 DashScope（通义万相 wan2.6 文生图）
DASHSCOPE_API_KEY=
# 中国大陆：https://dashscope.aliyuncs.com；国际版：https://dashscope-intl.aliyuncs.com
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
ALIYUN_WAN_MODEL=wan2.6-t2i
# ALIYUN_WAN_I2I_MODEL=wan2.6-image-to-image

# 火山方舟 Ark（字节 Seedream 5 图像编辑：cutout/upscale/expand/inpaint）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_MODEL=doubao-seedream-5-0-260128
# Studio 图像工具（expand 等）：mock | auto（P4 起接真供应商）
TOOL_IMAGE_PROVIDER=auto
# Studio 工具 Provider（每组取值：mock | seedream | http | auto，默认 auto）
# auto 优先级：seedream（ARK_API_KEY）→ http（TOOL_*_HTTP_URL）→ mock
#
# 抠图 cutout（seedream：指令生成透明背景 PNG；http：自建网关）
# TOOL_CUTOUT_PROVIDER=auto
# TOOL_CUTOUT_HTTP_URL=
# TOOL_CUTOUT_HTTP_KEY=
#
# 超分 upscale + 增强 enhance（seedream：指令放大；http：自建网关，按 scale/factor）
# TOOL_UPSCALE_PROVIDER=auto
# TOOL_UPSCALE_HTTP_URL=
# TOOL_UPSCALE_HTTP_KEY=
#
# 扩图 expand + 局部 inpaint（seedream：编辑接口；http：自建网关）
# TOOL_EDIT_PROVIDER=auto
# TOOL_EDIT_HTTP_URL=
# TOOL_EDIT_HTTP_KEY=

# 焦点编辑：识别 provider（mock | vision | auto；auto 有 DASHSCOPE_API_KEY 时走 VL）
# FOCUS_POINT_PROVIDER=auto
# FOCUS_VISION_MODEL=qwen-vl-plus
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# 提示词润色（template-mock | openai | auto；auto 有 Key 时走 Chat，失败回落模板）
PROMPT_OPTIMIZE_PROVIDER=auto

# Agent 编排 LLM（P0+P1：/agent/plan、/agent/runs；无 Key 时回落关键词 planner）
AGENT_LLM_ENABLED=true
AGENT_LLM_PRIMARY=deepseek
AGENT_LLM_FALLBACKS=qwen,glm
AGENT_LLM_ALLOW_OVERSEAS=false
# 海外模型开启后可将 claude 加入 AGENT_LLM_FALLBACKS=deepseek,qwen,glm,claude

# P3：VLM 出图质检（Agent Run observe 节点）
# AGENT_VLM_ENABLED=true
# AGENT_VLM_PROVIDER=auto
# AGENT_VLM_QWEN_MODEL=qwen-vl-max-latest
# AGENT_VLM_MAX_STEP_RETRIES=1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AGENT_LLM_DEEPSEEK_MODEL=deepseek-chat
# 与通义万相同 Key，走 compatible-mode Chat
# DASHSCOPE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AGENT_LLM_QWEN_MODEL=qwen-max
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AGENT_LLM_GLM_MODEL=glm-4-plus
# AGENT_LLM_OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# AGENT_LLM_CLAUDE_MODEL=claude-sonnet-4-20250514

# 长 Skill 流水线（P2：未配置 Inngest 时在 API 进程内 inline 执行）
# INNGEST_EVENT_KEY=dev
# INNGEST_BASE_URL=http://127.0.0.1:8288
INTERNAL_API_SECRET=change-me-internal
# WORKFLOW_WORKER_PORT=8288
# API_URL=http://localhost:4000

# 管理后台密钥（请求头 X-Admin-Secret）
ADMIN_SECRET=aimarket-admin-dev

# Phase 6A: 内容审核（local | openai | http | auto）
MODERATION_PROVIDER=auto
MODERATION_HTTP_URL=
MODERATION_HTTP_KEY=
OPENAI_MODERATION_MODEL=omni-moderation-latest
# 出图后审核（true | false；默认在配置 openai/http 时开启，仅 mock 本地图可关）
MODERATION_OUTPUT=

# Phase 6C: 限流存储（memory | redis | auto，auto 在 JOB_QUEUE=redis 时用 Redis）
RATE_LIMIT_STORE=auto

# Phase 5: 任务队列（memory | redis，redis 需 REDIS_URL）
JOB_QUEUE=memory
REDIS_URL=redis://127.0.0.1:6379
JOB_CONCURRENCY=2

# Phase 5: 支付（mock | stripe | auto）
PAYMENT_PROVIDER=auto
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Phase 5: 视频 Provider（mock | http | auto）
VIDEO_PROVIDER=auto
VIDEO_API_URL=
VIDEO_API_KEY=
