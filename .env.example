# Web (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4000
# 默认 true：生成任务走 SSE（失败降级轮询）；设 false 仅轮询
NEXT_PUBLIC_USE_JOB_STREAM=true

# API (apps/api)
PORT=4000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-in-production
DATABASE_PATH=./data/aimarket.db
# PostgreSQL（可选，见 docs/DEPLOY.md；需运行 postgres-bootstrap 迁移）
# DATABASE_URL=postgresql://user:pass@localhost:5432/aimarket

UPLOAD_DIR=./uploads

# 对象存储 / CDN（local | s3 | auto）
STORAGE_PROVIDER=auto
S3_BUCKET=
S3_REGION=ap-guangzhou
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=
S3_PREFIX=uploads/
S3_FORCE_PATH_STYLE=false
S3_ACL=public-read
MOCK_GENERATION_DELAY_MS=2500
PUBLIC_WEB_URL=http://localhost:3000

# Sprint 2: 图像 Provider（mock | openai | auto）
# staging 建议 openai + 填写 OPENAI_API_KEY，见 docs/STAGING.md
IMAGE_PROVIDER=auto
# Studio 图像工具（expand 等）：mock | auto（P4 起接真供应商）
TOOL_IMAGE_PROVIDER=auto
# 抠图 cutout：auto 时 P4-2 使用 tool-cutout-mock（PNG 占位）；后续接 matting HTTP
# TOOL_CUTOUT_PROVIDER=auto
# 超分/增强 upscale|enhance：auto 时 P4-3 使用 tool-upscale-mock（2x/4x 由 scale 与 prompt 解析）
# TOOL_UPSCALE_PROVIDER=auto
# 扩图/局部 expand|inpaint：auto 时 P4-4 使用 tool-edit-mock
# TOOL_EDIT_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_BASE_URL=https://api.openai.com/v1

# 管理后台密钥（请求头 X-Admin-Secret）
ADMIN_SECRET=aimarket-admin-dev

# Phase 6A: 内容审核（local | openai | http | auto）
MODERATION_PROVIDER=auto
MODERATION_HTTP_URL=
MODERATION_HTTP_KEY=
OPENAI_MODERATION_MODEL=omni-moderation-latest
# 出图后审核（true | false；默认在配置 openai/http 时开启，仅 mock 本地图可关）
MODERATION_OUTPUT=

# Phase 6C: 限流存储（memory | redis | auto，auto 在 JOB_QUEUE=redis 时用 Redis）
RATE_LIMIT_STORE=auto

# Phase 5: 任务队列（memory | redis，redis 需 REDIS_URL）
JOB_QUEUE=memory
REDIS_URL=redis://127.0.0.1:6379
JOB_CONCURRENCY=2

# Phase 5: 支付（mock | stripe | auto）
PAYMENT_PROVIDER=auto
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Phase 5: 视频 Provider（mock | http | auto）
VIDEO_PROVIDER=auto
VIDEO_API_URL=
VIDEO_API_KEY=
