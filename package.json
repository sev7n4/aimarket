{
  "name": "aimarket",
  "private": true,
  "version": "0.1.0",
  "description": "中文 AI 修图与电商设计平台",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @aimarket/web dev",
    "dev:api": "pnpm --filter @aimarket/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.29.3"
}
